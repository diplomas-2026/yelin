digraph database_schema {
  graph [rankdir=LR, splines=ortho, overlap=false, fontsize=18];
  node [shape=plain, fontname="Arial"];
  edge [fontname="Arial", fontsize=10];
  label="yelin — full database schema";
  labelloc=t;

  "app_users" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>app_users</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;app_users_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">full_name</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">email</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">password_hash</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">role</TD><TD ALIGN="LEFT">character varying(40)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">position_title</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">phone</TD><TD ALIGN="LEFT">character varying(40)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">department</TD><TD ALIGN="LEFT">character varying(120)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">active</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT true</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT CURRENT_TIMESTAMP</TD></TR></TABLE>>];
  "chat_messages" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>chat_messages</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;chat_messages_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">project_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → projects.id</TD></TR><TR><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → app_users.id</TD></TR><TR><TD ALIGN="LEFT">message</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT CURRENT_TIMESTAMP</TD></TR></TABLE>>];
  "documents" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>documents</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;documents_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">project_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → projects.id</TD></TR><TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">type</TD><TD ALIGN="LEFT">character varying(120)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">file_name</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">version</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 1</TD></TR><TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">character varying(40)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">uploaded_by</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → app_users.id</TD></TR><TR><TD ALIGN="LEFT">uploaded_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT CURRENT_TIMESTAMP</TD></TR><TR><TD ALIGN="LEFT">comment</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">mime_type</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">file_content</TD><TD ALIGN="LEFT">bytea</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
  "flyway_schema_history" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>flyway_schema_history</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">installed_rank</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">PK, NOT NULL</TD></TR><TR><TD ALIGN="LEFT">version</TD><TD ALIGN="LEFT">character varying(50)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">character varying(200)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">type</TD><TD ALIGN="LEFT">character varying(20)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">script</TD><TD ALIGN="LEFT">character varying(1000)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">checksum</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">installed_by</TD><TD ALIGN="LEFT">character varying(100)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">installed_on</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">execution_time</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">success</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
  "project_engineers" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>project_engineers</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">project_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, FK → projects.id</TD></TR><TR><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, FK → app_users.id</TD></TR></TABLE>>];
  "projects" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>projects</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;projects_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">customer</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">address</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">object_type</TD><TD ALIGN="LEFT">character varying(120)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">character varying(40)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">manager_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → app_users.id</TD></TR><TR><TD ALIGN="LEFT">start_date</TD><TD ALIGN="LEFT">date</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">planned_finish_date</TD><TD ALIGN="LEFT">date</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">actual_finish_date</TD><TD ALIGN="LEFT">date</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT CURRENT_TIMESTAMP</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT CURRENT_TIMESTAMP</TD></TR></TABLE>>];

  "chat_messages" -> "projects" [label="project_id → id"];
  "chat_messages" -> "app_users" [label="user_id → id"];
  "documents" -> "projects" [label="project_id → id"];
  "documents" -> "app_users" [label="uploaded_by → id"];
  "project_engineers" -> "projects" [label="project_id → id"];
  "project_engineers" -> "app_users" [label="user_id → id"];
  "projects" -> "app_users" [label="manager_id → id"];
}