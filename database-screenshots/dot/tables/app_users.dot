digraph single_table {
  graph [rankdir=TB, fontsize=18];
  node [shape=plain, fontname="Arial"];
  label="yelin — app_users";
  labelloc=t;
  "app_users" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>app_users</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;app_users_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">full_name</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">email</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">password_hash</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">role</TD><TD ALIGN="LEFT">character varying(40)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">position_title</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">phone</TD><TD ALIGN="LEFT">character varying(40)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">department</TD><TD ALIGN="LEFT">character varying(120)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">active</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT true</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT CURRENT_TIMESTAMP</TD></TR></TABLE>>];
}